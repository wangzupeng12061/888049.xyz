---
import Icon from './Icon.astro';
import { site } from '../data/site';
import { getLang, localizePath } from '../i18n';
const lang = getLang(Astro.url.pathname);
---
<footer>
  <div class="footer-main">
    <div>
      <p class="eyebrow">{lang === 'zh' ? '保持联系' : 'Keep in touch'}</p>
      <h2>{lang === 'zh' ? <>思想因交流<br />而愈发清晰。</> : <>Ideas become clearer<br />when they are shared.</>}</h2>
    </div>
    <a class="round-link" href={site.github} target="_blank" rel="noreferrer" aria-label="GitHub profile"><Icon name="github" /></a>
  </div>
  <div class="footer-meta">
    <span>© {new Date().getFullYear()} Wang Zupeng</span>
    <span>{lang === 'zh' ? '使用 Astro 构建 · 托管于 Azure' : 'Built with Astro · Hosted on Azure'}</span>
    <a href={localizePath('/contact', lang)}>{lang === 'zh' ? '联系' : 'Contact'}</a>
  </div>
</footer>
