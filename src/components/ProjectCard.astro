---
import Icon from './Icon.astro';
interface Props { project: { slug: string; number: string; title: string; role: string; description: string; tags: string[] } }
const { project } = Astro.props;
---
<article class="project-card">
  <div class="project-top"><span>{project.number}</span><span>{project.role}</span></div>
  <div>
    <h3>{project.title}</h3>
    <p>{project.description}</p>
  </div>
  <div class="project-bottom">
    <ul>{project.tags.map((tag) => <li>{tag}</li>)}</ul>
    <a href={`/projects#${project.slug}`} aria-label={`Read about ${project.title}`}><Icon name="arrow" /></a>
  </div>
</article>
